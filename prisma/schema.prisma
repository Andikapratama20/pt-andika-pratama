generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
}

model Pendaftaran {
  id            String   @id @default(cuid())
  namaLengkap   String
  nomorHP       String
  layanan       String
  durasi        String
  bank          String
  rekening      String
  fotoUrl       String?
  tanggalDaftar DateTime @default(now())
}
