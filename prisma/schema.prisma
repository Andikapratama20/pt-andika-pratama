generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Testimoni {
  id          String   @id @default(cuid())
  kategori    String
  imageUrl    String
  keterangan  String?
  urutan      Int      @default(0)
  aktif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
